# ============================================
# Hệ thống kiểm soát ra vào thư viện VTS
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (đổi thành key ngẫu nhiên trong production)
JWT_SECRET=your-secret-key-change-in-production

# ============================================
# Firebase Firestore Configuration
# ============================================
# Chọn 1 trong 2 cách sau:

# Cách 1: Dùng biến môi trường (copy toàn bộ JSON từ serviceAccountKey.json)
# Lưu ý: JSON phải trên 1 dòng, không có xuống dòng
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id",...}

# Cách 2: Dùng file JSON (khuyến nghị cho development)
# Đặt file serviceAccountKey.json vào thư mục config/
FIREBASE_KEY_PATH=./config/serviceAccountKey.json

# ============================================
# SQLite (Legacy - đã chuyển sang Firebase)
# ============================================
# DB_PATH=./database/library.db